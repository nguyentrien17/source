# Server environment variables

# App
NODE_ENV=development
PORT=5000

# Security
# Comma-separated origins, e.g. http://localhost:5173,https://your-domain.com
CORS_ORIGIN=http://localhost:5173

# Set to 1 only if behind a reverse proxy (nginx, cloudflare, etc.)
TRUST_PROXY=0

# Redis (recommended for multi-instance production)
# Example: redis://localhost:6379
REDIS_URL=

# Brute-force protection (login lockout)
MAX_LOGIN_ATTEMPTS=8
LOGIN_ATTEMPT_WINDOW_MINUTES=15
LOGIN_LOCK_MINUTES=15

# CSP tuning (production only). Comma-separated.
# Example connect-src: https://api.yourdomain.com,https://sentry.io
CSP_CONNECT_SRC=
CSP_IMG_SRC=
CSP_STYLE_SRC=
CSP_SCRIPT_SRC=
CSP_FONT_SRC=

# Database (MySQL)
DB_HOST=localhost
DB_NAME=rent_a_room
DB_USER=root
DB_PASS=your_password

# Auth
JWT_SECRET=change_me_to_a_long_random_string
